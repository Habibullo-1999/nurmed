{
  "server": {
    "host": "0.0.0.0",
    "port": ":9050",
    "version": "v1"
  },
  "database": {
    "dns": "postgres://app:strongpassword@postgres:5432/app?sslmode=disable",
    "migration": "postgres://app:strongpassword@postgres:5432/app?sslmode=disable"
  },
  "auth": {
    "jwtSecret": "replace-this-secret-with-a-strong-random-value",
    "accessTtlMinutes": 15,
    "refreshTtlDays": 30,
    "maxFailedAttempts": 5,
    "lockDurationMinutes": 15,
    "refreshCookieName": "refresh_token",
    "secureCookies": false,
    "loginRateLimitPerMinute": 20
  },
  "redis": {
    "host": "redis",
    "port": 6379
  }
}
